{
  "name": "social-custom",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "preview": "vite preview",
    "lint": "eslint src tests vitest.config.js vite.config.js --ext js,jsx --report-unused-disable-directives --max-warnings 50",
    "test": "vitest run --exclude tests/firestore.rules.test.js",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run tests/firestore.rules.test.js\"",
    "emulators": "firebase emulators:start --only auth,firestore",
    "build:firebase": "npm run build",
    "deploy": "node scripts/deploy.js",
    "deploy:hosting": "node scripts/deploy.js --hosting-only",
    "deploy:all": "node scripts/deploy.js",
    "generate:icons": "node scripts/generate-beautiful-icons.js",
    "migrate:comments": "node scripts/migrate-comments.js",
    "backfill:search": "node scripts/backfill-display-name-lower.js",
    "firebase:init": "npx firebase init hosting"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "firebase": "^10.14.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.54.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^24.0.0",
    "vitest": "^1.3.1",
    "autoprefixer": "^10.4.16",
    "chalk": "^5.3.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "firebase-tools": "^13.0.0",
    "ora": "^7.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8"
  }
}
